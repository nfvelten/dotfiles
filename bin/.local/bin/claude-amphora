#!/usr/bin/env bash

# Verifica se o scratchpad esta visivel agora (antes do toggle)
visible=$(hyprctl workspaces -j | python3 -c "
import json, sys
ws = json.load(sys.stdin)
print('yes' if any(w.get('name') == 'special:claude-amphora' for w in ws) else 'no')
" 2>/dev/null)

# Se a janela nao existe, cria e aguarda ela aparecer no scratchpad
if ! hyprctl clients -j | grep -q '"class": "claude-amphora"'; then
  alacritty --class claude-amphora -e bash -c "cd $HOME/amphora && exec claude" &
  for _ in $(seq 1 20); do
    sleep 0.1
    hyprctl clients -j | grep -q '"class": "claude-amphora"' && break
  done
fi

# Toggle: mostra ou esconde o scratchpad
hyprctl dispatch togglespecialworkspace claude-amphora

# Foca a janela somente ao mostrar (nao ao esconder)
if [ "$visible" = "no" ]; then
  sleep 0.05
  hyprctl dispatch focuswindow class:claude-amphora
fi
