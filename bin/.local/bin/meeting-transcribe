#!/usr/bin/env python3
# Transcreve um arquivo de áudio com faster-whisper
# Uso: meeting-transcribe <arquivo.wav>
import sys
from faster_whisper import WhisperModel

audio_file = sys.argv[1] if len(sys.argv) > 1 else "/tmp/meeting-record.wav"
model = WhisperModel("small", device="cpu", compute_type="int8")
segments, _ = model.transcribe(audio_file, language="pt", beam_size=5)
for seg in segments:
    text = seg.text.strip()
    if text and not all(c == '.' for c in text):
        print(text)
