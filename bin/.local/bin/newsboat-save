#!/usr/bin/env bash
# newsboat-save <url>
# Faz scraping do artigo, resume com claude e salva no vault

URL="$1"
TITLE_ARG="$2"   # Passado pelo newsboat via bookmark-cmd
VAULT="$HOME/amphora"
DATE=$(date +%d-%m-%Y)
MONTHS=("" "Janeiro" "Fevereiro" "Março" "Abril" "Maio" "Junho" "Julho" "Agosto" "Setembro" "Outubro" "Novembro" "Dezembro")
DAILY="$VAULT/Daily Notes/$(date +%Y)/${MONTHS[$(date +%-m)]}/$DATE.md"

notify-send -a "Newsboat" "📰 Salvando..." "$URL"

# Extrai conteúdo limpo com rdrview
CONTENT=$(rdrview -T body "$URL" 2>/dev/null)

if [ -z "$CONTENT" ]; then
  # Fallback: w3m renderiza HTML como texto limpo
  CONTENT=$(curl -sL "$URL" 2>/dev/null | w3m -dump -T text/html 2>/dev/null | head -c 8000)
fi

# Título: prioriza o passado pelo newsboat, depois fallback HTML
if [ -n "$TITLE_ARG" ]; then
  TITLE="$TITLE_ARG"
else
  RAW_HTML=$(curl -sL "$URL" 2>/dev/null)
  HTML_TITLE=$(echo "$RAW_HTML" | grep -oiP '(?<=<title>)[^<]+' | head -1 | sed 's/^[[:space:]]*//; s/[[:space:]]*$//')
  TITLE=$(echo "$HTML_TITLE" | python3 -c "import sys, html; print(html.unescape(sys.stdin.read().strip()))" 2>/dev/null)
fi

if [ -z "$CONTENT" ]; then
  notify-send -a "Newsboat" "❌ Erro" "Não foi possível extrair o conteúdo."
  exit 1
fi

TITLE="${TITLE:-Artigo sem título}"

# Resumo com claude
SUMMARY=$("$HOME/.local/bin/claude" -p "Você é um assistente de leitura. Resuma o artigo abaixo em português com: **Ideia principal**, **Pontos-chave** (3-5 bullets) e **Por que importa**. Seja conciso.

$CONTENT" < /dev/null 2>/dev/null)

# Nome do arquivo — limpa título para uso como nome
SAFE_TITLE=$(echo "$TITLE" | tr -d '/:*?"<>|\\' | cut -c1-60)
NOTE_FILE="$VAULT/Pessoal/Leituras/${SAFE_TITLE}.md"
mkdir -p "$VAULT/Pessoal/Leituras"

# Não duplica se já existe
if [ -f "$NOTE_FILE" ]; then
  notify-send -a "Newsboat" "⚠️ Já existe" "[[Leituras/$SAFE_TITLE]]"
  exit 0
fi

cat > "$NOTE_FILE" <<NOTE
---
tags: [leitura, artigo]
criado: $DATE
url: $URL
---
# $TITLE

## Resumo

$SUMMARY
NOTE

# Linka na daily note
if [ -f "$DAILY" ]; then
  if grep -q "^### Notas Rápidas" "$DAILY"; then
    sed -i "/^### Notas Rápidas/a - 📰 [[Leituras/${SAFE_TITLE}]] — artigo salvo" "$DAILY"
  fi
fi

notify-send -a "Newsboat" "✅ Salvo" "[[Leituras/$SAFE_TITLE]]" -t 6000
