#!/usr/bin/env bash
# meeting-record — records meeting, transcribes with faster-whisper and summarizes with claude
# Super+R: start recording | Super+R again: stop and process

PIDFILE="/tmp/meeting-record.pid"
AUDIOFILE="/tmp/meeting-record.wav"
VAULT="${AMPHORA_VAULT:-$HOME/amphora}"
MEETINGS_DIR="$VAULT/${AMPHORA_DIR_WORK:-Work}/Meetings"
# Find your sink with: pw-cli list-objects | grep -A2 'alsa_output'
SINK_MONITOR="${AMPHORA_SINK_MONITOR:-$(pw-cli list-objects 2>/dev/null | grep -o 'alsa_output[^"]*monitor' | head -1)}"

notify() {
  notify-send -a "Meeting Record" "$1" "$2" ${3:+-t $3}
}

# --- STOP recording and process ---
if [ -f "$PIDFILE" ]; then
  PID=$(cat "$PIDFILE")
  kill "$PID" 2>/dev/null
  rm -f "$PIDFILE"

  # Move audio to persistent location immediately
  mkdir -p "$MEETINGS_DIR"
  DATE=$(date +%d-%m-%Y)
  TIME=$(date +%H:%M)
  SAFE_AUDIOFILE="$MEETINGS_DIR/recording-$DATE-${TIME//:/-}.wav"
  sleep 1
  mv "$AUDIOFILE" "$SAFE_AUDIOFILE"

  notify "⏹ Recording stopped" "Transcribing in background..."

  (
    # Transcription
    TRANSCRIPT=$("$HOME/.local/bin/meeting-transcribe" "$SAFE_AUDIOFILE" 2>/tmp/meeting-transcribe.log)

    if [ -z "$TRANSCRIPT" ]; then
      notify "❌ No speech detected" "Audio saved at: $(basename "$SAFE_AUDIOFILE")"
      exit 1
    fi

    # Summarize with claude CLI
    PROMPT_FILE=$(mktemp /tmp/meeting-prompt.XXXXXX)
    cat > "$PROMPT_FILE" <<PROMPT
You are an assistant that summarizes corporate meetings. Based on the transcript below, generate a structured summary with: **Context**, **Decisions made**, **Next steps** and **Participants mentioned** (if identifiable). Be concise and direct.

Transcript:
$TRANSCRIPT
PROMPT
    SUMMARY=$("$HOME/.local/bin/claude" -p "$(cat "$PROMPT_FILE")" < /dev/null 2>/tmp/meeting-claude.log)
    rm -f "$PROMPT_FILE"

    # Save note to vault
    FILENAME="$MEETINGS_DIR/Meeting $DATE.md"

    # If note for the day already exists, increment
    COUNT=2
    while [ -f "$FILENAME" ]; do
      FILENAME="$MEETINGS_DIR/Meeting $DATE ($COUNT).md"
      COUNT=$((COUNT + 1))
    done

    cat > "$FILENAME" <<NOTE
---
tags: [meeting, work]
created: $DATE
---
# Meeting — $DATE $TIME

## Summary

$SUMMARY

---

## Full Transcript

$TRANSCRIPT
NOTE

    # Link in daily note
    MONTHS=("" "Janeiro" "Fevereiro" "Março" "Abril" "Maio" "Junho" "Julho" "Agosto" "Setembro" "Outubro" "Novembro" "Dezembro")
    DAILY="$VAULT/Daily Notes/$(date +%Y)/${MONTHS[$(date +%-m)]}/$DATE.md"
    NOTE_NAME=$(basename "$FILENAME" .md)

    if [ -f "$DAILY" ]; then
      if grep -q "^### Quick Notes" "$DAILY"; then
        sed -i "/^### Quick Notes/a - [[${NOTE_NAME}]] — meeting recorded at $TIME" "$DAILY"
      fi
    fi

    rm -f "$SAFE_AUDIOFILE"
    notify "✅ Meeting saved" "[[${NOTE_NAME}]]" 8000
  ) &

  exit 0
fi

# --- START recording ---
pw-record --target="$SINK_MONITOR" "$AUDIOFILE" &
echo $! > "$PIDFILE"
notify "🔴 Recording meeting" "Super+R to stop and process"
