#!/usr/bin/env bash
# video-note <url> — downloads YouTube subtitles, summarizes with claude and saves to the vault

URL="$1"
VAULT="${AMPHORA_VAULT:-$HOME/amphora}"
DATE=$(date +%d-%m-%Y)
MONTHS=("" "Janeiro" "Fevereiro" "Março" "Abril" "Maio" "Junho" "Julho" "Agosto" "Setembro" "Outubro" "Novembro" "Dezembro")
DAILY="$VAULT/Daily Notes/$(date +%Y)/${MONTHS[$(date +%-m)]}/$DATE.md"
TMPDIR=$(mktemp -d /tmp/video-note.XXXXXX)

if [ -z "$URL" ]; then
  echo "Usage: video-note <url>"
  exit 1
fi

notify-send -a "Video Note" "🎬 Fetching subtitles..." "$URL"

# Download subtitles (en, pt, pt-BR — in order of preference)
yt-dlp \
  --no-playlist \
  --write-auto-sub \
  --write-sub \
  --sub-lang "en,pt,pt-BR" \
  --sub-format "vtt" \
  --skip-download \
  --ignore-errors \
  --extractor-args "youtube:skip=dash,hls" \
  --output "$TMPDIR/%(title)s" \
  "$URL" 2>/tmp/video-note.log

# Get video title
TITLE=$(yt-dlp --no-playlist --get-title "$URL" 2>/dev/null)
if [ -z "$TITLE" ]; then
  notify-send -a "Video Note" "❌ Error" "Could not access the video."
  rm -rf "$TMPDIR"
  exit 1
fi

# Find the subtitle file
SUB_FILE=$(find "$TMPDIR" -name "*.vtt" | head -1)

if [ -z "$SUB_FILE" ]; then
  notify-send -a "Video Note" "❌ No subtitles" "$TITLE"
  rm -rf "$TMPDIR"
  exit 1
fi

# Clean VTT — remove timestamps, tags and duplicates
TRANSCRIPT=$(cat "$SUB_FILE" \
  | grep -v '^WEBVTT' \
  | grep -v '^NOTE' \
  | grep -v '^$' \
  | grep -v '^[0-9]' \
  | sed 's/<[^>]*>//g' \
  | sed '/^[0-9:.]* --> /d' \
  | awk '!seen[$0]++' \
  | tr '\n' ' ' \
  | sed 's/  */ /g')

if [ -z "$TRANSCRIPT" ]; then
  notify-send -a "Video Note" "❌ Empty subtitles" "$TITLE"
  rm -rf "$TMPDIR"
  exit 1
fi

notify-send -a "Video Note" "✍️ Generating summary..." "$TITLE"

# Summarize with claude
SUMMARY=$("$HOME/.local/bin/claude" -p "You are a study assistant. Based on the video transcript below, generate a summary with: **Main topic**, **Key points** (3-6 bullets) and **Conclusion**. Be concise and direct.

Title: $TITLE

Transcript:
$TRANSCRIPT" < /dev/null 2>/dev/null)

# Save note
SAFE_TITLE=$(echo "$TITLE" | tr -d '/:*?"<>|\\' | cut -c1-60)
mkdir -p "$VAULT/${AMPHORA_DIR_PERSONAL:-Personal}/Videos"
NOTE_FILE="$VAULT/${AMPHORA_DIR_PERSONAL:-Personal}/Videos/${SAFE_TITLE}.md"

cat > "$NOTE_FILE" <<NOTE
---
tags: [video, study]
created: $DATE
url: $URL
---
# $TITLE

## Summary

$SUMMARY

---

## Transcript

$TRANSCRIPT
NOTE

# Link in daily note
if [ -f "$DAILY" ]; then
  if grep -q "^### Quick Notes" "$DAILY"; then
    sed -i "/^### Quick Notes/a - 🎬 [[Videos/${SAFE_TITLE}]] — video watched" "$DAILY"
  fi
fi

rm -rf "$TMPDIR"
notify-send -a "Video Note" "✅ Saved" "[[Videos/$SAFE_TITLE]]" -t 6000
