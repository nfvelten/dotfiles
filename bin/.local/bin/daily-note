#!/usr/bin/env bash
# Requires: Hyprland + alacritty + nvim
# Configure via env var: AMPHORA_VAULT (default: ~/amphora)
VAULT="${AMPHORA_VAULT:-$HOME/amphora}"
months=("" "Janeiro" "Fevereiro" "Março" "Abril" "Maio" "Junho" "Julho" "Agosto" "Setembro" "Outubro" "Novembro" "Dezembro")
today=$(date +%d-%m-%Y)
daily="$VAULT/Daily Notes/$(date +%Y)/${months[$(date +%-m)]}/$today.md"

# Create daily note from template if it doesn't exist
if [ ! -f "$daily" ]; then
  mkdir -p "$(dirname "$daily")"
  weekday=$(date +%A)
  {
    printf -- "---\n"
    printf "id: \"%s\"\n" "$today"
    printf "aliases: []\n"
    printf "tags:\n  - daily_notes\nenergia: \nmood: \n"
    printf -- "---\n"
    printf "## Daily Tasks — %s (%s)\n\n" "$today" "$weekday"
    printf "### Main Focus\n\n*\n\n---\n\n"
    printf "### Tasks: #personal\n\n"
    printf "* [ ] Go to the gym\n"
    printf "* [ ] Read 30 minutes\n"
    printf "* [ ] Study 1 hour\n\n"
    printf "### Tasks: #work\n\n"
    printf "* [ ]\n\n---\n\n"
    printf "### Quick Notes\n\n*\n\n"
    printf "### Day Highlight\n\n*\n\n"
    printf "### 📝 Notes Log\n\n"
    printf "| Time | Note | Context |\n"
    printf "|------|------|----------|\n\n"
    printf "### Incomplete tasks\n"
    printf '```tasks\n'
    printf "not done\n"
    printf "path includes Daily Notes/%s.md\n" "$today"
    printf '```\n'
  } > "$daily"
fi

# Check if the scratchpad is currently visible (before toggle)
visible=$(hyprctl workspaces -j | python3 -c "
import json, sys
ws = json.load(sys.stdin)
print('yes' if any(w.get('name') == 'special:daily-note' for w in ws) else 'no')
" 2>/dev/null)

# If the window doesn't exist, create it and wait for it to appear in the scratchpad
if ! hyprctl clients -j | grep -q '"class": "daily-note"'; then
  alacritty --class daily-note -e nvim "$daily" &
  for _ in $(seq 1 20); do
    sleep 0.1
    hyprctl clients -j | grep -q '"class": "daily-note"' && break
  done
fi

# Toggle: show or hide the scratchpad
hyprctl dispatch togglespecialworkspace daily-note

# Focus the window only when showing (not when hiding)
if [ "$visible" = "no" ]; then
  sleep 0.05
  hyprctl dispatch focuswindow class:daily-note
fi
