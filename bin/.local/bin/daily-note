#!/usr/bin/env bash
VAULT="${AMPHORA_VAULT:-$HOME/amphora}"
months=("" "Janeiro" "Fevereiro" "Março" "Abril" "Maio" "Junho" "Julho" "Agosto" "Setembro" "Outubro" "Novembro" "Dezembro")
today=$(date +%d-%m-%Y)
daily="$VAULT/Daily Notes/$(date +%Y)/${months[$(date +%-m)]}/$today.md"

if [ ! -f "$daily" ]; then
  mkdir -p "$(dirname "$daily")"
  weekday=$(date +%A)
  {
    printf -- "---\n"
    printf "id: \"%s\"\n" "$today"
    printf "aliases: []\n"
    printf "tags:\n  - daily_notes\nenergia: \nmood: \n"
    printf -- "---\n"
    printf "## Daily Tasks — %s (%s)\n\n" "$today" "$weekday"
    printf "### Main Focus\n\n*\n\n---\n\n"
    printf "### Tasks: #personal\n\n"
    printf "* [ ] Go to the gym\n"
    printf "* [ ] Read 30 minutes\n"
    printf "* [ ] Study 1 hour\n\n"
    printf "### Tasks: #work\n\n"
    printf "* [ ]\n\n---\n\n"
    printf "### Quick Notes\n\n*\n\n"
    printf "### Day Highlight\n\n*\n\n"
    printf "### 📝 Notes Log\n\n"
    printf "| Time | Note | Context |\n"
    printf "|------|------|----------|\n\n"
    printf "### Incomplete tasks\n"
    printf '```tasks\n'
    printf "not done\n"
    printf "path includes Daily Notes/%s.md\n" "$today"
    printf '```\n'
  } > "$daily"
fi

if hyprctl clients -j | jq -e '.[] | select(.workspace.name == "special:daily-note")' > /dev/null 2>&1; then
    hyprctl dispatch togglespecialworkspace daily-note
else
    hyprctl dispatch exec "[workspace special:daily-note silent;float;size 1100 650;center] ghostty --font-size=11 -e nvim '$daily'"
    sleep 0.5
    hyprctl dispatch togglespecialworkspace daily-note
fi
