#!/usr/bin/env bash
months=("" "Janeiro" "Fevereiro" "Março" "Abril" "Maio" "Junho" "Julho" "Agosto" "Setembro" "Outubro" "Novembro" "Dezembro")
today=$(date +%d-%m-%Y)
daily="$HOME/amphora/Daily Notes/$(date +%Y)/${months[$(date +%-m)]}/$today.md"

# Cria a daily note com template se nao existir
if [ ! -f "$daily" ]; then
  mkdir -p "$(dirname "$daily")"
  weekday=$(LC_TIME=pt_BR.UTF-8 date +%A 2>/dev/null)
  if [[ "$weekday" =~ ^[A-Z] ]]; then
    case "$weekday" in
      Monday)    weekday="segunda-feira" ;;
      Tuesday)   weekday="terça-feira" ;;
      Wednesday) weekday="quarta-feira" ;;
      Thursday)  weekday="quinta-feira" ;;
      Friday)    weekday="sexta-feira" ;;
      Saturday)  weekday="sábado" ;;
      Sunday)    weekday="domingo" ;;
    esac
  fi
  {
    printf -- "---\n"
    printf "id: \"%s\"\n" "$today"
    printf "aliases: []\n"
    printf "tags:\n  - daily_notes\nenergia: \nmood: \n"
    printf -- "---\n"
    printf "## Tarefas do Dia - %s (%s)\n\n" "$today" "$weekday"
    printf "### Foco Principal do Dia\n\n*\n\n---\n\n"
    printf "### Lista de Tarefas: #pessoal\n\n"
    printf "* [ ] Ir a academia\n"
    printf "* [ ] Ler 30 minutos\n"
    printf "* [ ] Estudar 1 hora\n\n"
    printf "### Lista de Tarefas: #trabalho\n\n"
    printf "* [ ]\n\n---\n\n"
    printf "### Notas Rápidas sobre as Tarefas / Resultados do Dia\n\n*\n\n"
    printf "### Highlight do Dia\n\n*\n\n"
    printf "### 📝 Log de Notas\n\n"
    printf "| Hora | Nota | Contexto |\n"
    printf "|------|------|----------|\n\n"
    printf "### Tarefas incompletas\n"
    printf '```tasks\n'
    printf "not done\n"
    printf "path includes Daily Notes/%s.md\n" "$today"
    printf '```\n'
  } > "$daily"
fi

# Verifica se o scratchpad esta visivel agora (antes do toggle)
visible=$(hyprctl workspaces -j | python3 -c "
import json, sys
ws = json.load(sys.stdin)
print('yes' if any(w.get('name') == 'special:daily-note' for w in ws) else 'no')
" 2>/dev/null)

# Se a janela nao existe, cria e aguarda ela aparecer no scratchpad
if ! hyprctl clients -j | grep -q '"class": "daily-note"'; then
  alacritty --class daily-note -e nvim "$daily" &
  for _ in $(seq 1 20); do
    sleep 0.1
    hyprctl clients -j | grep -q '"class": "daily-note"' && break
  done
fi

# Toggle: mostra ou esconde o scratchpad
hyprctl dispatch togglespecialworkspace daily-note

# Foca a janela somente ao mostrar (nao ao esconder)
if [ "$visible" = "no" ]; then
  sleep 0.05
  hyprctl dispatch focuswindow class:daily-note
fi
