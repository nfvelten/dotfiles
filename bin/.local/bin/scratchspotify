#!/bin/bash
if hyprctl clients -j | jq -e '.[] | select(.workspace.name == "special:spotify")' > /dev/null 2>&1; then
    hyprctl dispatch togglespecialworkspace spotify
else
    hyprctl dispatch exec "[workspace special:spotify silent;float;size 1100 650;center] ghostty --font-size=11 -e spotify_player"
    sleep 0.5
    hyprctl dispatch togglespecialworkspace spotify
fi
